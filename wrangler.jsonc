{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "chatgpt-transit-workers",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-20",
  "compatibility_flags": [ "nodejs_compat" ],
  "assets": {
    "directory": "./public/",
    "binding": "ASSETS",
    "run_worker_first": true
  }
}
